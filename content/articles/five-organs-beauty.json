      { "type": "list", "items": ["Rosy complexion, moist skin", "Red, full lips", "Good appetite, normal digestion", "Abundant energy"] },
      { "type": "subheading", "text": "Signs of Spleen Deficiency" },
      { "type": "list", "items": ["Sallow complexion, facial puffiness", "Pale lips", "Poor appetite, bloating", "Fatigue, lethargy"] },
